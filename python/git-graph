#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.10"
# ///
"""Show recent commits with a visual +/- bar graph."""
import argparse
import re
import subprocess
import sys

GREEN = "\033[32m"
RED = "\033[31m"
DIM = "\033[2m"
RESET = "\033[0m"
BOLD = "\033[1m"
BAR_WIDTH = 40


def trunc(s: str, w: int) -> str:
    return s if len(s) <= w else s[: w - 1] + "…"


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "-n", "--count", type=int, default=3,
        help="number of commits to show (default: 3)",
    )
    args = parser.parse_args()

    try:
        result = subprocess.run(
            [
                "git", "log",
                "--pretty=format:COMMIT|%h|%s",
                "--shortstat", "--no-merges",
                f"-{args.count}",
            ],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        sys.stderr.write(e.stderr or "git log failed\n")
        return e.returncode
    except FileNotFoundError:
        sys.stderr.write("git not found on PATH\n")
        return 127

    commits: list[dict] = []
    current: dict | None = None
    for line in result.stdout.split("\n"):
        if line.startswith("COMMIT|"):
            _, h, subject = line.split("|", 2)
            current = {"hash": h, "subject": subject, "add": 0, "rem": 0}
            commits.append(current)
        elif current and ("insertion" in line or "deletion" in line):
            m_add = re.search(r"(\d+) insertion", line)
            m_rem = re.search(r"(\d+) deletion", line)
            if m_add:
                current["add"] = int(m_add.group(1))
            if m_rem:
                current["rem"] = int(m_rem.group(1))

    if not commits:
        print("No commits found.")
        return 0

    max_val = max((c["add"] + c["rem"] for c in commits), default=1)

    print(f'{BOLD}{"hash":<8} {"   +":>6} {"   -":>6}  {"graph":<41}  subject{RESET}')
    print("─" * 110)
    for c in commits:
        total = c["add"] + c["rem"]
        if total == 0 or max_val == 0:
            bar = " " * BAR_WIDTH
        else:
            add_w = round(c["add"] / max_val * BAR_WIDTH)
            rem_w = round(c["rem"] / max_val * BAR_WIDTH)
            pad = " " * (BAR_WIDTH - add_w - rem_w)
            bar = f'{GREEN}{"█" * add_w}{RESET}{RED}{"█" * rem_w}{RESET}{pad}'
        print(
            f'{DIM}{c["hash"]}{RESET} '
            f'{GREEN}+{c["add"]:<5}{RESET} '
            f'{RED}-{c["rem"]:<5}{RESET}  '
            f'{bar}  {trunc(c["subject"], 50)}'
        )

    print()
    print(
        f"{DIM}Bar scaled to max total ({max_val:,} lines in one commit). "
        f"{len(commits)} commits shown.{RESET}"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
