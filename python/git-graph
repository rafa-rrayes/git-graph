#!/usr/bin/env -S uv run --script --quiet
# /// script
# requires-python = ">=3.10"
# ///
"""Show recent commits with a visual +/- bar graph."""
import argparse
import math
import os
import re
import shutil
import subprocess
import sys
import time

HASH_W = 8
PM_W = 6
AUTHOR_W = 12
TIME_W = 4
BAR_MAX = 40
BAR_MIN = 10
SUBJECT_MIN = 15


def trunc(s: str, w: int) -> str:
    if w <= 0:
        return ""
    return s if len(s) <= w else s[: w - 1] + "…"


def pad(s: str, w: int) -> str:
    s = trunc(s, w)
    return s + " " * (w - len(s))


def relative_time(ts: int, now: int) -> str:
    d = max(0, now - ts)
    if d < 60:
        return f"{d}s"
    if d < 3600:
        return f"{d // 60}m"
    if d < 86400:
        return f"{d // 3600}h"
    if d < 86400 * 7:
        return f"{d // 86400}d"
    if d < 86400 * 30:
        return f"{d // (86400 * 7)}w"
    if d < 86400 * 365:
        return f"{d // (86400 * 30)}mo"
    return f"{d // (86400 * 365)}y"


def main() -> int:
    parser = argparse.ArgumentParser(
        description=__doc__,
        usage="git-graph [options] [<ref>...] [-- <path>...]",
    )
    parser.add_argument("-n", "--count", type=int, default=10,
                        help="number of commits to show (default: 10)")
    parser.add_argument("--author", help="filter to commits by author (substring match)")
    parser.add_argument("--since", help="only commits after this date (any git date string)")
    parser.add_argument("--until", help="only commits before this date (any git date string)")
    parser.add_argument("--merges", action="store_true",
                        help="include merge commits (excluded by default)")
    parser.add_argument("--log-scale", action="store_true",
                        help="scale bars logarithmically (useful when one commit dwarfs the rest)")
    parser.add_argument("--sort", choices=["date", "churn"], default="date",
                        help="sort order (default: date)")
    parser.add_argument("--no-color", action="store_true", help="disable color output")
    parser.add_argument("refs", nargs="*",
                        help="optional refs or revision ranges (e.g. main, v1.0..HEAD)")

    argv = sys.argv[1:]
    if "--" in argv:
        idx = argv.index("--")
        pre, paths = argv[:idx], argv[idx + 1:]
    else:
        pre, paths = argv, []
    args = parser.parse_args(pre)

    use_color = (
        sys.stdout.isatty()
        and "NO_COLOR" not in os.environ
        and not args.no_color
    )
    if use_color:
        GREEN, RED, DIM, RESET, BOLD = (
            "\033[32m", "\033[31m", "\033[2m", "\033[0m", "\033[1m"
        )
        ins_ch = del_ch = "█"
    else:
        GREEN = RED = DIM = RESET = BOLD = ""
        ins_ch, del_ch = "+", "-"

    cmd = [
        "git", "log",
        "--pretty=format:COMMIT|%h|%an|%at|%ad|%s",
        "--date=format-local:%b %d",
        "--shortstat",
    ]
    if not args.merges:
        cmd.append("--no-merges")
    if args.author:
        cmd.append(f"--author={args.author}")
    if args.since:
        cmd.append(f"--since={args.since}")
    if args.until:
        cmd.append(f"--until={args.until}")
    cmd.append(f"-{args.count}")
    cmd.extend(args.refs)
    if paths:
        cmd.append("--")
        cmd.extend(paths)

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
    except subprocess.CalledProcessError as e:
        sys.stderr.write(e.stderr or "git log failed\n")
        return e.returncode
    except FileNotFoundError:
        sys.stderr.write("git not found on PATH\n")
        return 127

    commits: list[dict] = []
    current: dict | None = None
    for line in result.stdout.split("\n"):
        if line.startswith("COMMIT|"):
            parts = line.split("|", 5)
            if len(parts) < 6:
                continue
            _, h, author, ts_str, date_str, subject = parts
            current = {
                "hash": h, "author": author, "ts": int(ts_str),
                "date": date_str, "subject": subject, "add": 0, "rem": 0,
            }
            commits.append(current)
        elif current and ("insertion" in line or "deletion" in line):
            if m := re.search(r"(\d+) insertion", line):
                current["add"] = int(m.group(1))
            if m := re.search(r"(\d+) deletion", line):
                current["rem"] = int(m.group(1))

    if not commits:
        print("No commits found.")
        return 0

    if args.sort == "churn":
        commits.sort(key=lambda c: c["add"] + c["rem"], reverse=True)

    term_w = shutil.get_terminal_size((80, 24)).columns
    fixed = HASH_W + 1 + PM_W + 1 + PM_W + 2 + 2 + AUTHOR_W + 1 + TIME_W + 2
    avail = max(BAR_MIN + SUBJECT_MIN, term_w - fixed)
    bar_w = max(BAR_MIN, min(BAR_MAX, avail - SUBJECT_MIN))
    subject_w = max(SUBJECT_MIN, avail - bar_w)

    scale = math.log1p if args.log_scale else float
    max_val = max((c["add"] + c["rem"] for c in commits), default=1) or 1
    scaled_max = scale(max_val) or 1.0
    now = int(time.time())

    print(
        f'{BOLD}{"hash":<{HASH_W}} {"   +":>{PM_W}} {"   -":>{PM_W}}  '
        f'{"graph":<{bar_w}}  '
        f'{"author":<{AUTHOR_W}} {"when":>{TIME_W}}  '
        f'subject{RESET}'
    )
    print("─" * term_w)

    for c in commits:
        total = c["add"] + c["rem"]
        if total == 0:
            bar = " " * bar_w
        else:
            bar_total = round(scale(total) / scaled_max * bar_w)
            bar_total = max(1, min(bar_w, bar_total))
            add_w = max(0, min(bar_total, round(bar_total * c["add"] / total)))
            rem_w = bar_total - add_w
            pad_w = bar_w - bar_total
            bar = (
                f'{GREEN}{ins_ch * add_w}{RESET}'
                f'{RED}{del_ch * rem_w}{RESET}'
                f'{" " * pad_w}'
            )
        print(
            f'{DIM}{c["hash"]}{RESET} '
            f'{GREEN}+{c["add"]:<5}{RESET} '
            f'{RED}-{c["rem"]:<5}{RESET}  '
            f'{bar}  '
            f'{pad(c["author"], AUTHOR_W)} '
            f'{relative_time(c["ts"], now):>{TIME_W}}  '
            f'{trunc(c["subject"], subject_w)}'
        )

    total_add = sum(c["add"] for c in commits)
    total_rem = sum(c["rem"] for c in commits)
    authors = len({c["author"] for c in commits})
    oldest = min(commits, key=lambda c: c["ts"])
    newest = max(commits, key=lambda c: c["ts"])
    if newest["ts"] - oldest["ts"] < 86400:
        span = newest["date"]
    else:
        days = (newest["ts"] - oldest["ts"]) // 86400
        span = f'{oldest["date"]} – {newest["date"]} ({days}d)'

    print()
    scale_note = " [log scale]" if args.log_scale else ""
    author_word = "author" if authors == 1 else "authors"
    commit_word = "commit" if len(commits) == 1 else "commits"
    print(
        f"{DIM}Bar scaled to max total ({max_val:,} lines in one commit){scale_note}. "
        f"{len(commits)} {commit_word} shown.{RESET}"
    )
    print(
        f"{DIM}+{total_add:,} / -{total_rem:,} across {authors} {author_word}, {span}.{RESET}"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
